{
  "compilerOptions": {
    "lib": ["DOM", "ES2015"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ES2015"
  },
  "include": ["src"]
}
